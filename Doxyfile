# Doxyfile configuration for Guillaume GUI Framework

# Project settings
PROJECT_NAME           = "Guillaume GUI Framework"
PROJECT_NUMBER         = "2.02"
PROJECT_BRIEF          = "A modern C++ GUI framework with SDL3 backend"
PROJECT_LOGO           = 

# Output settings
OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO
OUTPUT_LANGUAGE        = English

# Input settings
INPUT                  = headers/ sources/ README.md
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.hpp *.cpp *.h *.c *.md
RECURSIVE              = YES
EXCLUDE                = external/ build/
EXCLUDE_PATTERNS       = */external/* */build/*

# Source browser settings
SOURCE_BROWSER         = YES
